# -------------------------------------------------------
# Auracut — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# -------------------------------------------------------

# Django
SECRET_KEY=AuraCut_2026
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (matches docker-compose service)
DB_NAME=auracut
DB_USER=auracut
DB_PASSWORD=auracut_password
DB_HOST=db
DB_PORT=5432

# Redis (matches docker-compose service)
REDIS_URL=redis://redis:6379

# Media storage — absolute path inside the container
MEDIA_ROOT=/app/media

# Max upload size in bytes (default: 2GB)
MAX_UPLOAD_SIZE=2147483648

# Production only — comma-separated
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
