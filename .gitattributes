# Auracut — enforce LF line endings for all text files
# Prevents Windows CRLF issues across the team

* text=auto eol=lf

# Shell scripts must always be LF (Docker runs on Linux)
*.sh text eol=lf

# Python
*.py text eol=lf

# Web
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.md text eol=lf

# Binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.mp4 binary
*.webm binary
*.mov binary
